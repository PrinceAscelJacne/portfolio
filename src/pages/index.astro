function toggleTheme() {
  var body = document.body;
  body.classList.toggle('light');
  var icon = body.classList.contains('light') ? '☀️' : '🌙';
  document.querySelectorAll('.theme-toggle').forEach(function(btn) { btn.textContent = icon; });
  localStorage.setItem('pad-theme', body.classList.contains('light') ? 'light' : 'dark');
}

function toggleLang(menuId) {
  var menu = document.getElementById(menuId);
