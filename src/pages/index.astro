    btn.textContent = isLight ? '☀️' : '🌙';
  });
  localStorage.setItem('pad-theme', isLight ? 'light' : 'dark');
}

function toggleLang(menuId) {
  var menu = document.getElementById(menuId);
  if (!menu) return;
  menu.classList.toggle('open');
  var otherId = menuId === 'langMenu' ? 'langMenuMobile' : 'langMenu';
  var other = document.getElementById(otherId);
  if (other) other.classList.remove('open');
}

function toggleContact(menuId) {
