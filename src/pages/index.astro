	</div>
</nav>

<main>
	<section id="about" class="hero">
		<div class="hero-left">
			<span class="badge">Disponible pour un stage · 3 mois</span>
			<h1 class="hero-name">Prince Ascel Jacné<br><em>Djibodé</em></h1>
			<div class="hero-role">
				<span>{profession} — Développeur Full Stack</span>
				<span>@ {school}</span>
			</div>
			<p class="hero-desc">{description}</p>
			<div class="hero-actions">
				<a href="#projects" class="btn-main">Voir mes projets</a>
				<a href="/CV_Prince_Ascel_DJIBODE.pdf" download class="btn-outline">↓ Télécharger CV</a>
				<div class="hero-meta">
					<span>📍 Mulhouse, France · Mobilité</span>
					<span>📞 07 45 36 03 07</span>
					<span>🔗 linkedin: Prince_Ascel_Jacne_DJIBODE</span>
				</div>
			</div>
		</div>
		<div class="hero-right">
			<div class="monogram-container">
				<div class="monogram-bg"></div>
				<div class="monogram-bg2"></div>
				<span class="monogram">PAD</span>
				<span class="corner-tag tl">MIAGE · L3</span>
				<span class="corner-tag br">Full Stack<br>Mulhouse</span>
			</div>
		</div>
	</section>

	<div class="divider"><div class="divider-line"></div><span class="divider-label">Compétences techniques</span><div class="divider-line"></div></div>

	<section id="skills" class="section">
		<div class="section-header">
			<span class="section-number">01</span>
			<h2 class="section-title">Domaines d'<em>expertise</em></h2>
		</div>
		<div class="skills-grid">
			{skills.map(group => (
				<div class="skill-card">
					<span class="skill-icon">{group.icon}</span>
					<h3>{group.category}</h3>
					<div class="tags">
						{group.items.map(item => <span class="tag">{item}</span>)}
					</div>
				</div>
			))}
		</div>
	</section>

	<div class="divider"><div class="divider-line"></div><span class="divider-label">Parcours académique</span><div class="divider-line"></div></div>

	<section id="formations" class="section">
		<div class="section-header">
			<span class="section-number">02</span>
			<h2 class="section-title">Formations &amp; <em>diplômes</em></h2>
		</div>
		<div class="formations-list">
			{formations.map(f => (
				<div class="formation-item">
					<div class="formation-period">{f.period}</div>
					<div class="formation-content">
						<span class="formation-degree">{f.degree}</span>
						<span class="formation-school">{f.school} — {f.location}</span>
					</div>
				</div>
			))}
		</div>
	</section>

	<div class="divider"><div class="divider-line"></div><span class="divider-label">Expérience professionnelle</span><div class="divider-line"></div></div>

	<section id="experience" class="section">
		<div class="section-header">
			<span class="section-number">03</span>
			<h2 class="section-title">Expériences <em>terrain</em></h2>
		</div>
		<div class="exp-list">
			{experiences.map(exp => (
				<div class="exp-card">
					<div class="exp-side">
						<span class="exp-type">{exp.type}</span>
						<span class="exp-date">{exp.date}</span>
						<span class="exp-company">{exp.company}</span>
						<span class="exp-location">{exp.location}</span>
					</div>
					<div class="exp-main">
						<h3>{exp.role}</h3>
						<ul class="exp-details">
							{exp.details.map(d => <li>{d}</li>)}
						</ul>
					</div>
				</div>
			))}
		</div>
	</section>

	<div class="divider"><div class="divider-line"></div><span class="divider-label">Réalisations personnelles</span><div class="divider-line"></div></div>

	<section id="projects" class="section">
		<div class="section-header">
			<span class="section-number">04</span>
			<h2 class="section-title">Projets <em>GitHub</em></h2>
		</div>
		<div class="projects-grid">
			{projects.map((p, i) => (
				<div class="project-card">
					{p.video
						? <video class="project-video" src={p.video} controls muted playsinline preload="metadata" />
						: p.image
							? <img class="project-img" src={p.image} alt={p.title} />
							: <div class="project-placeholder-img"><span>Aperçu à venir</span></div>
					}
					<span class="project-number">PROJET 0{i + 1}</span>
					<h3 class="project-title">{p.title}</h3>
					<p class="project-desc">{p.description}</p>
					<div class="project-tech">
						{p.tech.map(t => <span class="tag">{t}</span>)}
					</div>
					<div class="project-footer">
						<a href={p.github} class="project-link" target="_blank" rel="noopener">Voir sur GitHub →</a>
					</div>
				</div>
			))}
		</div>
	</section>

	<div class="divider"><div class="divider-line"></div><span class="divider-label">Profil complet</span><div class="divider-line"></div></div>

	<section class="section">
		<div class="section-header">
			<span class="section-number">05</span>
			<h2 class="section-title">Langues, <em>atouts</em> & intérêts</h2>
		</div>
		<div class="aside-grid">
			<div class="aside-card">
				<h3>Langues</h3>
				<div class="lang-list">
					{languages.map(l => (
						<div class="lang-item">
							<div class="lang-row">
								<span class="lang-name">{l.lang}</span>
								<span class="lang-level">{l.level}</span>
							</div>
							<div class="lang-bar">
								<div class="lang-bar-fill" style={`width: ${l.pct}%`}></div>
							</div>
						</div>
					))}
				</div>
			</div>
			<div class="aside-card">
				<h3>Atouts</h3>
				<div class="pill-list">
					{softSkills.map(s => <span class="pill">{s}</span>)}
				</div>
			</div>
			<div class="aside-card">
				<h3>Centres d'intérêt</h3>
				<div class="pill-list">
					{interests.map(i => <span class="pill interest">{i}</span>)}
				</div>
			</div>
		</div>
	</section>

	<footer>
		<span class="footer-left">DJIBODE Prince Ascel Jacné — Portfolio 2025</span>
		<span class="footer-right">djibodeprinceascel@gmail.com</span>
	</footer>
</main>

