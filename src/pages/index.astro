function toggleLang() {
  const menu = document.getElementById('langMenu');
  menu.classList.toggle('open');
  document.getElementById('langMenuMobile').classList.remove('open');
}
function toggleLangMobile() {
  const menu = document.getElementById('langMenuMobile');
  menu.classList.toggle('open');
  document.getElementById('langMenu').classList.remove('open');
}

function setLang(lang) {
  const t = translations[lang];

  // ── Buttons
  const btn = document.getElementById('langBtn');
  btn.textContent = t.flag + ' ' + t.code + ' ▾';
  const mobile = document.getElementById('langBtnMobile');
  if (mobile) mobile.textContent = t.flag;

  // ── Nav links
  const navLinks = document.querySelectorAll('.nav-links a:not(.nav-cv):not(.nav-cta)');
  navLinks.forEach((a, i) => { if (t.nav[i]) a.textContent = t.nav[i]; });
  document.querySelectorAll('.nav-cv').forEach(el => el.textContent = t.dl);
  document.querySelectorAll('.nav-cta').forEach(el => el.textContent = t.contact);

  // ── Badge
  const badge = document.querySelector('.badge');
  if (badge) badge.childNodes[badge.childNodes.length - 1].textContent = ' ' + t.badge;

  // ── Hero desc, role, school
  const heroDesc = document.querySelector('.hero-desc');
  if (heroDesc) heroDesc.textContent = t.desc;
  const roleLines = document.querySelectorAll('.hero-role span');
  if (roleLines[0]) roleLines[0].textContent = t.role;
  if (roleLines[1]) roleLines[1].textContent = t.school;

  // ── Hero buttons
  const btnMain = document.querySelector('.btn-main');
  if (btnMain) btnMain.textContent = t.btnProjects;
  const btnOutline = document.querySelector('.btn-outline');
  if (btnOutline) btnOutline.textContent = t.btnCV;

  // ── Location
  const metaSpans = document.querySelectorAll('.hero-meta span');
  if (metaSpans[0]) metaSpans[0].textContent = t.location;

  // ── Section titles (with em)
  const titles = document.querySelectorAll('.section-title');
  const tKeys = [
    {t:'s1t',em:'s1em',rest:''},
    {t:'s2t',em:'s2em',rest:''},
    {t:'s3t',em:'s3em',rest:''},
    {t:'s4t',em:'s4em',rest:''},
    {t:'s5t',em:'s5em',rest:'s5rest'}
  ];
  titles.forEach((el, i) => {
    const k = tKeys[i];
    if (!k) return;
    el.innerHTML = (t[k.t]||'') + '<em>' + (t[k.em]||'') + '</em>' + (t[k.rest]||'');
  });

  // ── Divider labels
  const divLabels = document.querySelectorAll('.divider-label');
  divLabels.forEach((el, i) => { if (t.div[i]) el.textContent = t.div[i]; });

  // ── Skill category headers
  const skillCatEls = document.querySelectorAll('.skill-card h3');
  skillCatEls.forEach((el, i) => { if (t.skillCats[i]) el.textContent = t.skillCats[i]; });

  // ── Aside titles
  const asideTitles = document.querySelectorAll('.aside-card h3');
  asideTitles.forEach((el, i) => { if (t.aside[i]) el.textContent = t.aside[i]; });

  // ── Footer
  const footerLeft = document.querySelector('.footer-left');
  if (footerLeft) footerLeft.textContent = t.footer;

  // ── Formations
  const formItems = document.querySelectorAll('.formation-item');
  formItems.forEach((el, i) => {
    if (!t.formations[i]) return;
    const period = el.querySelector('.formation-period');
    const degree = el.querySelector('.formation-degree');
    const school = el.querySelector('.formation-school');
    if (period) period.textContent = t.formations[i].period;
    if (degree) degree.textContent = t.formations[i].degree;
    if (school) school.textContent = t.formations[i].school;
  });

  // ── Experiences
  const expCards = document.querySelectorAll('.exp-card');
  expCards.forEach((el, i) => {
    const typeEl = el.querySelector('.exp-type');
    const roleEl = el.querySelector('.exp-main h3');
    if (typeEl) typeEl.textContent = t.expType;
    if (roleEl && t.expRoles[i]) roleEl.textContent = t.expRoles[i];
    const details = el.querySelectorAll('.exp-details li');
    if (t.expDetails[i]) {
      details.forEach((li, j) => { if (t.expDetails[i][j]) li.textContent = t.expDetails[i][j]; });
    }
  });

  // ── Projects
  const projCards = document.querySelectorAll('.project-card');
  projCards.forEach((el, i) => {
    if (!t.projects[i]) return;
    const titleEl = el.querySelector('.project-title');
    const descEl = el.querySelector('.project-desc');
    const linkEl = el.querySelector('.project-link');
    if (titleEl) titleEl.textContent = t.projects[i].title;
    if (descEl) descEl.textContent = t.projects[i].desc;
    if (linkEl) linkEl.textContent = t.projects[i].link;
  });

  // ── Language names in aside
  const langNames = document.querySelectorAll('.lang-name');
  langNames.forEach((el, i) => { if (t.langNames[i]) el.textContent = t.langNames[i]; });

  // ── Soft skills pills
  const softPills = document.querySelectorAll('.aside-card:nth-child(2) .pill');
  softPills.forEach((el, i) => { if (t.softSkills[i]) el.textContent = t.softSkills[i]; });

  // ── Interests pills
  const intPills = document.querySelectorAll('.aside-card:nth-child(3) .pill');
  intPills.forEach((el, i) => { if (t.interests[i]) el.textContent = t.interests[i]; });

  // ── Active option
  document.querySelectorAll('.lang-option').forEach(o => o.classList.remove('active'));
  document.querySelectorAll(`.lang-option[onclick="setLang('${lang}')"]`).forEach(el => el.classList.add('active'));
  document.getElementById('langMenu').classList.remove('open');
  document.getElementById('langMenuMobile').classList.remove('open');

  localStorage.setItem('pad-lang', lang);
}

// ── INIT ──
document.addEventListener('DOMContentLoaded', () => {
  const savedTheme = localStorage.getItem('pad-theme');
  if (savedTheme === 'light') {
    document.body.classList.add('light');
    document.getElementById('themeToggle').textContent = '☀️';
  }
  const savedLang = localStorage.getItem('pad-lang');
  if (savedLang && savedLang !== 'fr') setLang(savedLang);

  // Close lang menu on outside click
  document.addEventListener('click', (e) => {
    if (!document.getElementById('langDropdown').contains(e.target)) {
      document.getElementById('langMenu').classList.remove('open');
    }
    if (!document.getElementById('langDropdownMobile').contains(e.target)) {
      document.getElementById('langMenuMobile').classList.remove('open');
    }
  });
});
</script>
</Layout>
