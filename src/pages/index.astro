function setLang(lang) {
  var t = T[lang]; if (!t) return;
  var b = document.getElementById('langBtn'); if (b) b.textContent = t.flag + ' ' + t.code + ' ▾';
  var bm = document.getElementById('langBtnMobile'); if (bm) bm.textContent = t.flag;
  document.querySelectorAll('.nav-links a:not(.nav-cv):not(.nav-cta)').forEach(function(a,i){if(t.nav[i])a.textContent=t.nav[i];});
  document.querySelectorAll('.nav-cv').forEach(function(el){el.textContent=t.dl;});
  document.querySelectorAll('.nav-cta').forEach(function(el){el.textContent=t.contact;});
  var badge=document.querySelector('.badge'); if(badge){var n=badge.childNodes;n[n.length-1].textContent=' '+t.badge;}
  var hd=document.querySelector('.hero-desc'); if(hd)hd.textContent=t.desc;
  var rs=document.querySelectorAll('.hero-role span'); if(rs[0])rs[0].textContent=t.role; if(rs[1])rs[1].textContent=t.school;
  var bMain=document.querySelector('.btn-main'); if(bMain)bMain.textContent=t.btnProjects;
  var bOut=document.querySelector('.btn-outline'); if(bOut)bOut.textContent=t.btnCV;
  var ms=document.querySelectorAll('.hero-meta span'); if(ms[0])ms[0].textContent=t.location;
  var titles=document.querySelectorAll('.section-title');
  var keys=[{t:'s1t',e:'s1em',r:''},{t:'s2t',e:'s2em',r:''},{t:'s3t',e:'s3em',r:''},{t:'s4t',e:'s4em',r:''},{t:'s5t',e:'s5em',r:'s5rest'}];
  titles.forEach(function(el,i){var k=keys[i];if(!k)return;el.innerHTML=(t[k.t]||'')+'<em>'+(t[k.e]||'')+'</em>'+(t[k.r]?t[k.r]:'');});
  document.querySelectorAll('.divider-label').forEach(function(el,i){if(t.div[i])el.textContent=t.div[i];});
  document.querySelectorAll('.skill-card h3').forEach(function(el,i){if(t.skillCats[i])el.textContent=t.skillCats[i];});
  document.querySelectorAll('.aside-card h3').forEach(function(el,i){if(t.aside[i])el.textContent=t.aside[i];});
  var fl=document.querySelector('.footer-left'); if(fl)fl.textContent=t.footer;
  document.querySelectorAll('.formation-item').forEach(function(el,i){
    if(!t.formations[i])return;
    var p=el.querySelector('.formation-period'),d=el.querySelector('.formation-degree'),s=el.querySelector('.formation-school');
    if(p)p.textContent=t.formations[i].period; if(d)d.textContent=t.formations[i].degree; if(s)s.textContent=t.formations[i].school;
  });
  document.querySelectorAll('.exp-card').forEach(function(el,i){
    var ty=el.querySelector('.exp-type'),ro=el.querySelector('.exp-main h3');
    if(ty)ty.textContent=t.expType; if(ro&&t.expRoles[i])ro.textContent=t.expRoles[i];
    if(t.expDetails[i])el.querySelectorAll('.exp-details li').forEach(function(li,j){if(t.expDetails[i][j])li.textContent=t.expDetails[i][j];});
  });
  document.querySelectorAll('.project-card').forEach(function(el,i){
    if(!t.projects[i])return;
    var ti=el.querySelector('.project-title'),de=el.querySelector('.project-desc'),li=el.querySelector('.project-link');
    if(ti)ti.textContent=t.projects[i].title; if(de)de.textContent=t.projects[i].desc; if(li)li.textContent=t.projects[i].link;
  });
  document.querySelectorAll('.lang-name').forEach(function(el,i){if(t.langNames[i])el.textContent=t.langNames[i];});
  document.querySelectorAll('.aside-card:nth-child(2) .pill').forEach(function(el,i){if(t.softSkills[i])el.textContent=t.softSkills[i];});
  document.querySelectorAll('.aside-card:nth-child(3) .pill').forEach(function(el,i){if(t.interests[i])el.textContent=t.interests[i];});
  document.querySelectorAll('.lang-option').forEach(function(o){o.classList.remove('active');});
  document.querySelectorAll('.lang-option[data-lang="'+lang+'"]').forEach(function(el){el.classList.add('active');});
  document.getElementById('langMenu').classList.remove('open');
  document.getElementById('langMenuMobile').classList.remove('open');
  localStorage.setItem('pad-lang', lang);
}

document.addEventListener('DOMContentLoaded', function() {
  if (localStorage.getItem('pad-theme') === 'light') {
    document.body.classList.add('light');
    document.querySelectorAll('.theme-toggle').forEach(function(b){b.textContent='☀️';});
  }
  document.querySelectorAll('.theme-toggle').forEach(function(btn){btn.addEventListener('click', toggleTheme);});
  var lb=document.getElementById('langBtn');
  if(lb)lb.addEventListener('click',function(e){e.stopPropagation();toggleLang('langMenu');});
  var lbm=document.getElementById('langBtnMobile');
  if(lbm)lbm.addEventListener('click',function(e){e.stopPropagation();toggleLang('langMenuMobile');});
  document.querySelectorAll('.lang-option[data-lang]').forEach(function(btn){
    btn.addEventListener('click',function(e){e.stopPropagation();setLang(btn.dataset.lang);});
  });
  document.addEventListener('click',function(){
    document.getElementById('langMenu').classList.remove('open');
    document.getElementById('langMenuMobile').classList.remove('open');
  });
  var saved=localStorage.getItem('pad-lang');
  if(saved&&saved!=='fr')setLang(saved);
});

})();
