---
import Layout from '../layouts/Layout.astro';
const fullName = "DJIBODE Prince Ascel Jacné";
const displayName = { first: "Prince Ascel Jacné", last: "Djibodé" };
const profession = "Étudiant en Licence 3 MIAGE";
const school = "Université de Haute-Alsace";
const description = "Étudiant en L3 MIAGE à FST UHA, je suis à la recherche d'un stage de 3 mois en tant que Développeur Full Stack. Passionné par la création d'applications web complètes, je maîtrise les environnements Front-end et Back-end. Rigoureux et curieux, je souhaite mettre mes compétences au service d'un projet concret au sein de votre équipe.";
const skills = [
    { category: "Web & Frameworks", items: ["HTML", "CSS", "JavaScript", "PHP", "Laravel", "Bootstrap"], icon: "◈" },
    { category: "Langages & Mobile", items: ["Flutter", "C++", "Python", "Java"], icon: "◇" },
    { category: "Analyse & BD", items: ["MySQL", "UML", "Merise"], icon: "◉" },
    { category: "Outils", items: ["VS Code", "Eclipse", "Code::Blocks", "Laragon", "XAMPP"], icon: "◫" }
];
const formations = [
    { degree: "Licence 3 MIAGE", school: "FST UHA", location: "Mulhouse", period: "Depuis 2025" },
    { degree: "Licence Pro. Analyse Informatique & Programmation", school: "ENEAM", location: "Cotonou, Bénin", period: "2023 — 2024" },
    { degree: "Baccalauréat Série D", school: "Sainte Jeanne d'Arc", location: "Bénin", period: "2020 — 2021" },
    { degree: "Brevet d'Étude du Premier Cycle", school: "CEG 1 Allada", location: "Bénin", period: "2016 — 2017" },
];
const experiences = [
    {
        role: "Développeur web",
        type: "Stage",
        company: "ASTUS CITEE",
        location: "Cotonou, Bénin",
        date: "Mai — Août 2024",
        details: [
            "Développement d'une application de gestion des fichiers (centralisation, sécurisation, accès documents)",
            "Création d'un site web vitrine pour renforcer la visibilité de l'entreprise",
            "Intégration d'une interface moderne et ergonomique",
            "Collaboration avec l'équipe interne pour recueillir les besoins et tester les fonctionnalités"
        ]
    },
    {
        role: "Analyste programmeur",
        type: "Stage",
        company: "Super U Erevan",
        location: "Bénin",
        date: "Juil. — Sept. 2023",
        details: [
            "Participation à la conception et au développement d'applications web",
            "Contribution à l'analyse des besoins et à la rédaction des cahiers des charges",
            "Intégration d'interfaces utilisateurs en HTML, CSS et JavaScript",
            "Collaboration avec l'équipe technique pour les tests et le déploiement"
        ]
    }
];
const projects = [
    {
        title: "Crypto — Chiffrement de messages",
        description: "Application de chiffrement polyalphabétique : l'utilisateur saisit un mot, une phrase ou un paragraphe, et le programme retourne le message codé en tenant compte des espaces.",
        tech: ["Python", "C++"],
        github: "https://github.com/PrinceAscelJacne/Crypto",
        image: "/images/crypto-illustration.svg",
        placeholder: false
    },
    {
        title: "Astus Citée — Gestion de fichiers",
        description: "Application web de gestion documentaire développée en stage : centralisation, sécurisation et accès aux fichiers internes de l'entreprise, avec interface moderne et ergonomique.",
        tech: ["Laravel", "PHP", "HTML", "SCSS", "JavaScript", "Blade", "MySQL"],
        github: "https://github.com/PrinceAscelJacne/Astus-Cit-e",
        video: "/videos/astus-gestion.mp4",
        placeholder: false
    },
    {
        title: "Gestionnaire de questionnaires",
        description: "Application en C++ permettant de gérer des questionnaires interactifs. Prend en charge plusieurs types de questions (texte, numérique, QCM), la sauvegarde depuis un fichier texte, et propose différents modes d'évaluation (test, seconde chance, adaptatif).",
        tech: ["C++"],
        github: "https://github.com/PrinceAscelJacne/Questionnaire-Cpp",
        image: "/images/questionnaire-illustration.svg",
        placeholder: false
    },
    {
        title: "Astus Citée — Site vitrine",
        description: "Site web vitrine développé en stage chez Astus Citée pour présenter l'entreprise et renforcer sa visibilité en ligne.",
        tech: ["HTML", "CSS", "JavaScript", "PHP"],
        github: "https://github.com/PrinceAscelJacne/Astus-Cit-e",
        video: "/videos/astus-citee.mp4",
        placeholder: false
    }
];
const languages = [
    { lang: "Français", level: "C2", pct: 100 },
    { lang: "Anglais", level: "B1", pct: 55 },
    { lang: "Allemand", level: "A2", pct: 30 },
];
const softSkills = ["Esprit d'équipe", "Dynamique & motivé", "Sens de l'analyse", "Capacité d'adaptation"];
const interests = ["Football", "Jeux vidéos", "Voyage", "Musique"];
---
<Layout title={fullName}>
<style is:global>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400&family=Syne:wght@400;600;700;800&display=swap');
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
--bg: #07080a; --surface: #0e1015; --surface2: #13161c;
--gold: #c9a84c; --gold-light: #e8c97a; --gold-dim: rgba(201,168,76,0.15);
--text: #eeeae3; --text-dim: #7a7570; --text-mid: #b5b0a8;
--border: rgba(201,168,76,0.18); --border-subtle: rgba(255,255,255,0.06);
}
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; overflow-x: hidden; min-height: 100vh; }
body::before {
content: ''; position: fixed; inset: 0;
background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
pointer-events: none; z-index: 9999; opacity: 0.4;
}
.ambient { position: fixed; top: -20vh; left: 50%; transform: translateX(-50%); width: 80vw; height: 60vh; background: radial-gradient(ellipse at center, rgba(201,168,76,0.07) 0%, transparent 70%); pointer-events: none; z-index: 0; }
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1.5rem 3rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-subtle); background: rgba(7,8,10,0.85); backdrop-filter: blur(20px); }
.logo { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; letter-spacing: 0.12em; color: var(--text); text-decoration: none; flex-shrink: 0; }
.logo em { color: var(--gold); font-style: italic; }
.nav-links { display: flex; align-items: center; gap: 2rem; }
.nav-links a { font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-dim); text-decoration: none; transition: color 0.25s; white-space: nowrap; }
.nav-links a:hover { color: var(--text); }
.nav-cta { color: var(--gold) !important; border: 1px solid var(--border) !important; padding: 0.55rem 1.2rem !important; transition: background 0.25s !important; }
.nav-cta:hover { background: var(--gold-dim) !important; }
.nav-cv { color: var(--text-dim) !important; border: 1px solid var(--border-subtle) !important; padding: 0.55rem 1.2rem !important; transition: color 0.25s, border-color 0.25s !important; text-decoration: none; }
.nav-cv:hover { color: var(--text) !important; border-color: var(--border) !important; }
.nav-mobile { display: none; }
main { position: relative; z-index: 1; }
.hero { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; align-items: center; padding: 8rem 4rem 4rem; gap: 4rem; max-width: 1300px; margin: 0 auto; }
.hero-left { display: flex; flex-direction: column; gap: 2rem; }
.badge { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); border: 1px solid var(--border); padding: 0.45rem 1rem; background: var(--gold-dim); width: fit-content; }
.badge::before { content: ''; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.4; transform:scale(0.7); } }
.hero-name { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.8rem, 5vw, 5rem); font-weight: 300; line-height: 1.05; }
.hero-name em { font-style: italic; color: var(--gold); }
.hero-role { font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.15em; color: var(--text-dim); text-transform: uppercase; display: flex; flex-direction: column; gap: 0.25rem; }
.hero-role span { color: var(--text-mid); }
.hero-desc { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 300; line-height: 1.75; color: var(--text-mid); max-width: 48ch; }
.hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
.btn-main { display: inline-block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--bg); background: var(--gold); padding: 0.9rem 2.2rem; text-decoration: none; font-weight: 600; transition: background 0.25s, transform 0.2s; white-space: nowrap; }
.btn-main:hover { background: var(--gold-light); transform: translateY(-1px); }
.btn-outline { display: inline-block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); background: transparent; border: 1px solid var(--border); padding: 0.9rem 2.2rem; text-decoration: none; font-weight: 600; white-space: nowrap; transition: background 0.25s, transform 0.2s; }
.btn-outline:hover { background: var(--gold-dim); transform: translateY(-1px); }
.hero-meta { display: flex; flex-direction: column; gap: 0.4rem; }
.hero-meta span { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; color: var(--text-dim); }
.hero-right { display: flex; justify-content: center; align-items: center; }
.monogram-container { position: relative; width: 320px; height: 320px; display: flex; align-items: center; justify-content: center; }
.monogram-bg { position: absolute; inset: 0; border: 1px solid var(--border); transform: rotate(15deg); opacity: 0.5; }
.monogram-bg2 { position: absolute; inset: 20px; border: 1px solid var(--border); transform: rotate(5deg); opacity: 0.3; }
.monogram { font-family: 'Cormorant Garamond', serif; font-size: 9rem; font-weight: 300; font-style: italic; color: transparent; -webkit-text-stroke: 1px rgba(201,168,76,0.4); line-height: 1; position: relative; z-index: 1; user-select: none; }
.corner-tag { position: absolute; font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; color: var(--text-dim); line-height: 1.6; }
.corner-tag.tl { top: 1rem; left: 1rem; }
.corner-tag.br { bottom: 1rem; right: 1rem; text-align: right; }
.divider { max-width: 1300px; margin: 0 auto; padding: 0 4rem; display: flex; align-items: center; gap: 2rem; }
.divider-line { flex: 1; height: 1px; background: var(--border-subtle); }
.divider-label { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-dim); }
.section { padding: 6rem 4rem; max-width: 1300px; margin: 0 auto; }
.section-header { display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 4rem; }
.section-number { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.15em; color: var(--gold); opacity: 0.7; }
.section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300; letter-spacing: -0.01em; }
.section-title em { font-style: italic; color: var(--gold); }
.skills-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; border: 1px solid var(--border-subtle); }
.skill-card { background: var(--surface); padding: 2rem; position: relative; overflow: hidden; transition: background 0.3s; }
.skill-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, var(--gold-dim) 0%, transparent 60%); opacity: 0; transition: opacity 0.3s; }
.skill-card:hover { background: var(--surface2); }
.skill-card:hover::before { opacity: 1; }
.skill-icon { font-size: 1.3rem; color: var(--gold); opacity: 0.6; margin-bottom: 0.8rem; display: block; }
.skill-card h3 { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 1.2rem; }
.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tag { font-family: 'Syne', sans-serif; font-size: 0.75rem; font-weight: 600; color: var(--text-mid); background: rgba(255,255,255,0.04); border: 1px solid var(--border-subtle); padding: 0.3rem 0.75rem; transition: border-color 0.2s, color 0.2s; }
.skill-card:hover .tag { border-color: var(--border); color: var(--text); }
.formations-list { display: flex; flex-direction: column; border: 1px solid var(--border-subtle); }
.formation-item { display: grid; grid-template-columns: 200px 1fr; background: var(--surface); border-bottom: 1px solid var(--border-subtle); transition: background 0.25s; position: relative; overflow: hidden; }
.formation-item:last-child { border-bottom: none; }
.formation-item::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--gold); transform: scaleY(0); transform-origin: bottom; transition: transform 0.3s; }
.formation-item:hover { background: var(--surface2); }
.formation-item:hover::after { transform: scaleY(1); }
.formation-period { padding: 1.5rem 1.5rem 1.5rem 2.5rem; border-right: 1px solid var(--border-subtle); display: flex; align-items: center; font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.06em; color: var(--text-dim); }
.formation-content { padding: 1.5rem 2rem; display: flex; flex-direction: column; justify-content: center; gap: 0.2rem; }
.formation-degree { font-family: 'Syne', sans-serif; font-size: 0.88rem; font-weight: 600; color: var(--text); }
.formation-school { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: var(--text-dim); }
.exp-list { display: flex; flex-direction: column; gap: 1px; background: var(--border-subtle); }
.exp-card { background: var(--surface); display: grid; grid-template-columns: 260px 1fr; transition: background 0.25s; position: relative; overflow: hidden; }
.exp-card::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--gold); transform: scaleY(0); transform-origin: bottom; transition: transform 0.35s ease; }
.exp-card:hover { background: var(--surface2); }
.exp-card:hover::after { transform: scaleY(1); }
.exp-side { padding: 2.5rem 2rem 2.5rem 3rem; border-right: 1px solid var(--border-subtle); display: flex; flex-direction: column; justify-content: center; gap: 0.4rem; }
.exp-type { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); opacity: 0.8; }
.exp-date { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--text-mid); }
.exp-company { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: var(--text); margin-top: 0.2rem; }
.exp-location { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; color: var(--text-dim); }
.exp-main { padding: 2.5rem 3rem; display: flex; flex-direction: column; justify-content: center; gap: 1rem; }
.exp-main h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; letter-spacing: -0.01em; }
.exp-details { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.exp-details li { font-family: 'Syne', sans-serif; font-size: 0.78rem; color: var(--text-dim); display: flex; align-items: flex-start; gap: 0.75rem; }
.exp-details li::before { content: '—'; color: var(--gold); opacity: 0.5; flex-shrink: 0; margin-top: 1px; }
.projects-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border-subtle); border: 1px solid var(--border-subtle); }
.project-card { background: var(--surface); padding: 2rem; display: flex; flex-direction: column; gap: 1.2rem; position: relative; overflow: hidden; transition: background 0.3s; }
.project-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(160deg, var(--gold-dim) 0%, transparent 50%); opacity: 0; transition: opacity 0.3s; }
.project-card:hover { background: var(--surface2); }
.project-card:hover::before { opacity: 1; }
.project-video { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; position: relative; z-index: 1; background: var(--surface2); border: 1px solid var(--border-subtle); }
.project-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; position: relative; z-index: 1; border: 1px solid var(--border-subtle); }
.project-number { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em; color: var(--gold); opacity: 0.6; position: relative; z-index: 1; }
.project-title { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; color: var(--text); position: relative; z-index: 1; }
.project-desc { font-family: 'Syne', sans-serif; font-size: 0.78rem; line-height: 1.65; color: var(--text-dim); position: relative; z-index: 1; flex: 1; }
.project-tech { display: flex; flex-wrap: wrap; gap: 0.4rem; position: relative; z-index: 1; }
.project-footer { display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 1; padding-top: 1rem; border-top: 1px solid var(--border-subtle); }
.project-link { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); text-decoration: none; transition: opacity 0.2s; }
.project-link:hover { opacity: 0.7; }
.aside-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: var(--border-subtle); border: 1px solid var(--border-subtle); }
.aside-card { background: var(--surface); padding: 2rem 2.5rem; }
.aside-card h3 { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); opacity: 0.7; margin-bottom: 1.5rem; }
.lang-list { display: flex; flex-direction: column; gap: 1rem; }
.lang-item { display: flex; flex-direction: column; gap: 0.4rem; }
.lang-row { display: flex; justify-content: space-between; align-items: baseline; }
.lang-name { font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 600; color: var(--text); }
.lang-level { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: var(--gold); }
.lang-bar { height: 2px; background: var(--border-subtle); position: relative; }
.lang-bar-fill { position: absolute; left: 0; top: 0; bottom: 0; background: var(--gold); opacity: 0.6; }
.pill-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.pill { font-family: 'Syne', sans-serif; font-size: 0.75rem; font-weight: 600; color: var(--text-mid); border: 1px solid var(--border-subtle); padding: 0.4rem 0.9rem; background: rgba(255,255,255,0.03); }
.pill.interest { color: var(--text-dim); font-size: 0.72rem; }
.nav-controls { display: flex; align-items: center; gap: 0.75rem; }
.theme-toggle { background: none; border: 1px solid var(--border-subtle); color: var(--text-dim); cursor: pointer; font-size: 0.85rem; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s, color 0.2s; flex-shrink: 0; }
.theme-toggle:hover { border-color: var(--border); color: var(--text); }
.lang-dropdown { position: relative; }
.lang-btn { background: none; border: 1px solid var(--border-subtle); color: var(--text-dim); cursor: pointer; font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; padding: 0 0.75rem; height: 34px; display: flex; align-items: center; gap: 0.4rem; transition: border-color 0.2s, color 0.2s; white-space: nowrap; flex-shrink: 0; }
.lang-btn:hover { border-color: var(--border); color: var(--text); }
.lang-menu { position: absolute; top: calc(100% + 6px); right: 0; background: var(--surface2); border: 1px solid var(--border); min-width: 130px; z-index: 200; display: none; flex-direction: column; }
.lang-menu.open { display: flex; }
.lang-option { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: var(--text-dim); padding: 0.6rem 1rem; cursor: pointer; border: none; background: none; text-align: left; width: 100%; transition: background 0.15s, color 0.15s; display: flex; align-items: center; gap: 0.5rem; }
.lang-option:hover { background: var(--gold-dim); color: var(--text); }
.lang-option.active { color: var(--gold); }
.contact-dropdown { position: relative; }
.contact-btn { cursor: pointer; font-family: "DM Mono", monospace; font-size: 0.65rem; letter-spacing: 0.1em; }
.contact-menu {
  position: absolute; top: calc(100% + 6px); right: 0;
  background: var(--surface2); border: 1px solid var(--border);
  min-width: 160px; z-index: 200; display: none; flex-direction: column;
}
.contact-menu.open { display: flex; }
.contact-menu-mobile { right: auto; left: 0; }
.contact-option {
  font-family: "DM Mono", monospace; font-size: 0.65rem; letter-spacing: 0.1em;
  color: var(--text-dim); padding: 0.65rem 1rem; text-decoration: none;
  border: none; background: none; text-align: left; width: 100%;
  transition: background 0.15s, color 0.15s; display: flex; align-items: center; gap: 0.6rem;
}
.contact-option:hover { background: var(--gold-dim); color: var(--text); }
body.light { --bg: #f8f6f2; --surface: #f0ede8; --surface2: #e8e4de; --text: #1a1810; --text-dim: #7a7570; --text-mid: #4a4640; --border: rgba(160,120,40,0.25); --border-subtle: rgba(0,0,0,0.08); --gold: #a07828; --gold-light: #c49a30; --gold-dim: rgba(160,120,40,0.1); }
footer { border-top: 1px solid var(--border-subtle); padding: 3rem 4rem; max-width: 1300px; margin: 6rem auto 0; display: flex; align-items: center; justify-content: space-between; }
.footer-left { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: var(--text-dim); }
.footer-right { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; color: var(--text-dim); }
@keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
.hero-left > * { animation: fadeUp 0.7s ease both; }
.hero-left > *:nth-child(1) { animation-delay: 0.1s; }
.hero-left > *:nth-child(2) { animation-delay: 0.2s; }
